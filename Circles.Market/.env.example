# Copy this file to .env and adjust as needed.
# Values here are safe defaults for local development. Do not use in production.

# --- Database Configuration ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=circles_market

# Single database for all market services (recommended for staging/production)
# For local dev with separate DBs, set different values for each
DB_MARKET_API=circles_market
DB_CODEDISP=circles_market
DB_ODOO=circles_market

POSTGRES_CONNECTION=Host=postgres;Port=5432;Database=circles_market;Username=postgres;Password=postgres

# --- Market API RPC ---
RPC=https://rpc.aboutcircles.com/
# Optional: separate RPC for circles_query calls (if not set, uses RPC)
# CIRCLES_RPC=https://rpc.aboutcircles.com/

# --- JWT Authentication (RS256/JWKS via external auth-service) ---
AUTH_SERVICE_URL=https://staging.circlesubi.network/auth
AUTH_JWT_ISSUER=circles-auth
AUTH_JWT_AUDIENCE=market-api

# --- IPFS ---
IPFS_RPC_URL=https://rpc.filebase.io/api/v0/
IPFS_RPC_BEARER=dev-placeholder-bearer
IPFS_GATEWAY_URL=https://cloudflare-ipfs.com/

# --- Service Ports ---
MARKET_API_PORT=5084
CODE_DISPENSER_PORT=5680
ODOO_ADAPTER_PORT=5678

# --- Optional ---
PUBLIC_BASE_URL=http://localhost:5084
CODE_POOLS_DIR=/app/pools
CODE_POOLS_HOST_DIR=./code-pools
